NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: personal access token for `supabase gen types` (NOT a project secret).
# Get one at https://supabase.com/dashboard/account/tokens — required only for local type regeneration.
# SUPABASE_ACCESS_TOKEN=
