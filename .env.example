NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Demo account — used by the seed script and by the "Try as Demo User" button
# on /login. Create the user in Supabase Auth, then paste their UUID here.
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=your-strong-password
DEMO_USER_ID=00000000-0000-0000-0000-000000000000

# Cron secret for the nightly demo-reset endpoint. Generate with
# `openssl rand -hex 32` and set the same value in Vercel env vars (all
# environments). Vercel auto-attaches it as Authorization: Bearer when
# CRON_SECRET is present.
CRON_SECRET=run-openssl-rand-hex-32-and-paste-here

# Optional: personal access token for `supabase gen types` (NOT a project secret).
# Get one at https://supabase.com/dashboard/account/tokens — required only for local type regeneration.
# SUPABASE_ACCESS_TOKEN=
